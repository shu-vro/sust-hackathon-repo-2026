{
  "name": "sust-hackathon",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch index.ts",
    "test": "bun test",
    "test:live-llm": "RUN_LIVE_LLM=1 bun test --timeout=180000 --max-concurrency=2 src/routes/analyze-ticket/sample-cases.agent.test.ts",
    "build:sample-pairs": "bun run scripts/build-sample-case-pairs.ts",
    "eval:sample-cases": "bun run scripts/evaluate-sample-cases.ts",
    "test:live-eval": "RUN_LIVE_EVAL=1 bun test --timeout=180000 --max-concurrency=1 src/routes/analyze-ticket/evaluation/sample-cases.parallel-eval.test.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "main": "index.ts",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/openrouter": "^0.4.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "langchain": "^1.5.2",
    "morgan": "^1.11.0",
    "zod": "^4.4.3"
  }
}
